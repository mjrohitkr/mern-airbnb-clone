<% layout("layouts/boilerplate.ejs") %>
<div class="mt-3">
    <h3><b>All Wanderlust</b> </h3>
    <!-- <form method="get" action="/listing/new"><button>Create New Listing</button></form> -->
   <br>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1">
        <% for(let list of allListing){%>
    <a href="/listing/<%=list._id%>" class="listing-link">
     <div class="card col">
  <img src="<%=list.image%>" class="card-img-top" alt="..." style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <h5 class="card-title"><b><%=list.title  %></b></h5>
    <p class="card-text">
        <%=list.description%> <br>
    &#8377; <%=list.price.toLocaleString("en-IN")%> / Night</p>
    
  </div>
</div>
</a>
        <% } %>
</div>
</div>


 

