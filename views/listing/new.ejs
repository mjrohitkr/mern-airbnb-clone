<% layout("layouts/boilerplate.ejs") %>

<body>
    
    <div class="row mt-3">
        <div class="col-8 offset-2" >
        
            <h3>Create a New Listing</h3>
    <form method="post" action="/listing" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" type="text" placeholder="Add a catchy" class="form-control" required>
            <div class="valid-feedback">Title Good Look</div>
            <div class="invalid-feedback">Please enter the valid title</div>
        </div>  
    
        <div class="mb-3">
            <label for="description" class="form-label" >Description</label>
            <textarea name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback">Please enter a short Description</div>
            <div class="valid-feedback">correct</div>
        </div>
    
        <div class="mb-3">
            <label for="image" class="form-label">Image</label>
            <input name="listing[image]" type="text" placeholder="Enter image URL/Link" class="form-control" >
            <div class="invalid-feedback">Please enter the valid image</div>
            <div class="valid-feedback">correct</div>
        </div>
  
    <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price" class="form-label" >Price</label>
            <input name="listing[price]" placeholder="1600" class="form-control" required>
            <div class="invalid-feedback">price should be valid</div>
            <div class="valid-feedback">correct</div>
        </div>
   
        <div class="mb-3 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" type="text" placeholder="Patna, Bihar" class="form-control" required>
            <div class="invalid-feedback">Please enter the valid location</div>
            <div class="valid-feedback">correct</div>

        </div>

    </div>
        
    <br>
        <div class="mb-3">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" type="text" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">Please enter the valid country</div>
            <div class="valid-feedback">correct</div>
        </div>
    <br>
    <button class="btn btn-dark add-btn">Add</button>
    <br><br>

    </form>
    </div>
    </div>

    
</body>
