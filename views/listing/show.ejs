<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">
    <h3>Listing Details</h3>
  </div>
    <div class="card col-6 offset-3 show-card">
  <img src="<%=allListing.image%>" class="card-img-top" alt="listing_image">
  <div class="card-body">
    <p class="card-texts mt-2">
        <b><%=allListing.title%></b><br>
        <%=allListing.description%> <br>
        &#8377; <%=allListing.price.toLocaleString("en-IN")%> <br>
        <%=allListing.location%> <br>
        <%=allListing.country%> <br>
    </p>
 </div>
  </div>

  <div class="btns">
        <a href="/listing/<%=allListing.id%>/edit" class="edit btn btn-dark col-1 offset-3 add-btn">Edit</a>

        <form method="post" action="/listing/<%=allListing.id%>?_method=DELETE">
        <button class="btn btn-dark add-btn-dl offset-5" onclick="return confirm('Are you sure?')">Delete</button>
    </form>
    </div>
   
 
</div>
    </div>
</body>
