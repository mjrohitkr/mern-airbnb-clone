<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
    <div class="col-6 offset-3" >
        <form action="/login" method="post" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="Username" class="form-label">Username</label>
            <input name="username" type="text" placeholder="Add a Username" id="Username" class="form-control" required>
            <div class="valid-feedback"> Good Username</div>
        </div>
    
        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input name="password" type="password" placeholder="Enter password" id="password" class="form-control" required>
            <div class="valid-feedback"> Good password</div>
            <div class="invalid-feedback">Please Enter password</div>
        </div>  
        <button class="btn btn-success">Login</button>
        


        </form>


    </div>
</div>